{
  "version": 2,
  "installCommand": "npm install -g pnpm@8 --silent && cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "npx prisma generate",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**", "prisma/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
